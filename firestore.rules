rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Collections ---

    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == request.auth.uid 
          && data.email is string 
          && data.displayName is string
          && data.phoneNumber is string
          && data.role in ['buyer', 'seller', 'admin']
          && data.createdAt is string;
      }

      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId 
        && incoming().role == existing().role // Role immutability
        && isValidUser(incoming());
    }

    match /products/{productId} {
      function isValidProduct(data) {
        return data.sellerId == request.auth.uid
          && data.name is string && data.name.size() > 0 && data.name.size() <= 200
          && data.price is number && data.price >= 0
          && data.stock is int && data.stock >= 0;
      }

      allow read: if true; // Public access to marketplace
      allow create: if hasRole('seller') && isValidProduct(incoming()) && isValidId(productId);
      allow update: if hasRole('seller') && existing().sellerId == request.auth.uid 
        && isValidProduct(incoming())
        && (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'stock', 'imageUrl', 'category']));
      allow delete: if hasRole('seller') && existing().sellerId == request.auth.uid;
    }

    match /carts/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /orders/{orderId} {
      function isValidOrder(data) {
        return data.userId == request.auth.uid
          && data.total is number && data.total >= 0
          && data.status in ['pending', 'completed', 'cancelled'];
      }

      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || hasRole('seller') || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming()) && isValidId(orderId);
      allow update: if (isAdmin() || (hasRole('seller') && incoming().diff(existing()).affectedKeys().hasOnly(['status'])))
        && isValidOrder(incoming());
    }
  }
}
